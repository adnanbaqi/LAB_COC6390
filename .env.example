# ─────────────────────────────────────────────────────────────
# Smart City Surveillance — Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smart_city

# Server
SERVER_PORT=8000
FLASK_DEBUG=0 
# set to 1 for hot-reload in development

# YOLO model weights (auto-downloaded if not present)
# Swap to yolov8s.pt or a custom fine-tuned model for better accuracy.
YOLO_MODEL=yolov8n.pt

# Snapshots
SNAPSHOT_DIR=snapshots  # relative to server working directory

# Parking dwell time before an event is raised (seconds)
PARKING_DWELL_SECONDS=10


##LIVE CAMERAS
CAMERA_1_ID=RASPPI, Aligarh
CAMERA_1_URL=http://172.20.10.3:5000/video_feed

CAMERA_2_ID=ABEY LONDON, UK
CAMERA_2_URL=https://www.youtube.com/live/M3EYAY2MftI?si=oDUcea2Q6aMkaDJQ

CAMERA_3_ID=TIMES SQUARE, New York
CAMERA_3_URL=https://www.youtube.com/live/rnXIjl_Rzy4?si=J6711PBt59EH7WI9

CAMERA_4_ID=LAPTOP CAMERA
CAMERA_4_URL=http://127.0.0.1:5123/video_feed

CAMERA_5_ID=FRESNO, California
CAMERA_5_URL=https://www.youtube.com/live/1xl0hX-nF2E?si=TX7BUwo3RJr8p36D

# YOLO Settings
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.35

# Set how often YOLO runs (in seconds). Default is 3.0
DETECTION_INTERVAL_SECONDS=4.5

# WhatsApp (Twilio) Settings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
SMS_TO=
# Email (RTO) Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RTO_EMAIL=
